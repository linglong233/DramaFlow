NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
DATA_DIR=./apps/api/data
UPLOADS_DIR=./apps/api/uploads
STORAGE_DRIVER=local
LOCAL_STORAGE_PUBLIC_URL=http://localhost:4000/uploads
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=dramaflow
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me-too
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API_KEY=replace-me
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_COMPAT_MOCK_FALLBACK=true
# Example for the validated third-party OpenAI-compatible gateway:
# OPENAI_COMPAT_BASE_URL=https://new-api.ms-egde.de5.net/v1
# OPENAI_TEXT_MODEL=moonshotai/kimi-k2-instruct
# OPENAI_COMPAT_MOCK_FALLBACK=false
MEDIA_IMAGE_MODEL=gpt-image-1
MEDIA_VIDEO_MODEL=sora-2