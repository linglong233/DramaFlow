generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  platform_super_admin
  user
}

enum TeamRole {
  tenant_owner
  tenant_admin
  member
}

enum ProjectRole {
  project_admin
  director
  writer
  artist
  reviewer
  viewer
}

enum ProjectPermission {
  project_view
  project_edit
  version_review
  job_manage
  timeline_edit
  export_create
  member_manage
  permission_manage
}

enum ReviewPolicyMode {
  inherit
  required
  bypass
}

enum ProjectStatus {
  draft
  in_progress
  completed
  archived
}

enum DocumentType {
  synopsis
  script
  storyboard
  image
  video
  audio
  subtitle
  world_bible
}

enum VersionStatus {
  draft
  submitted
  pending_review
  approved
  rejected
}

enum AnchorType {
  document
  scene
  shot
  asset
}

enum JobType {
  script_generation
  synopsis_generation
  storyboard_generation
  image_generation
  video_generation
  rewrite_segment
  tts_generation
  export_video
  shot_regenerate
  novel_import
  impact_suggestion
  shot_composition
}

enum JobStatus {
  queued
  running
  completed
  failed
}

enum JobPriority {
  low
  normal
  high
}

enum AuditContentType {
  script
  storyboard
  image
  video
}

enum AuditAction {
  submitted
  advanced
  approved
  rejected
  adopted
  restored
  deleted
}

enum NotificationType {
  task_completed
  task_failed
  review_submitted
  review_approved
  review_rejected
  comment_added
  comment_reply
  member_invited
}

enum ProjectInviteStatus {
  pending
  accepted
}

enum DependencyType {
  world_bible_to_synopsis
  world_bible_to_script
  world_bible_to_storyboard
  synopsis_to_script
  script_to_storyboard
  storyboard_to_media
  manual_inherited
  manual_unlinked
}

enum DependencyAnchorType {
  document
  scene
  shot
  asset
}

enum ImpactIssueStatus {
  open
  suggested
  accepted
  ignored
  resolved
}

enum ImpactSeverity {
  low
  medium
  high
}

enum ImpactTargetType {
  version
  scene
  shot
  media_candidate
  timeline_clip
}

enum ImpactSuggestionStatus {
  generated
  accepted
  acceptance_reverted
}

enum ImpactIssueEventType {
  created
  ignored
  reopened
  suggestion_created
  suggestion_accepted
  acceptance_reverted
  resolved
  assigned
}

enum BatchJobStatus {
  running
  completed
  partial_failure
}

enum ExportFormat {
  mp4
  mov
  webm
}

enum ExportStatus {
  pending
  processing
  completed
  failed
}

enum NovelImportStatus {
  draft
  queued
  running
  needs_review
  failed
  cancelled
  written
}

enum NovelImportStage {
  setup
  chunking
  adaptationPlan
  worldBible
  synopsis
  script
  review
  write
}

model User {
  id                    String     @id
  email                 String     @unique
  displayName           String
  passwordHash          String
  globalRole            GlobalRole
  llmConfig             Json?
  imageGenerationConfig Json?
  imageProviders        Json?
  videoProviders        Json?
  defaultImageProvider  String?
  defaultVideoProvider  String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  refreshTokens  RefreshToken[]
  teamMembers    TeamMember[]
  projectMembers ProjectMember[]
  notifications  Notification[]
}

model RefreshToken {
  id        String   @id
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Team {
  id                             String           @id
  name                           String
  slug                           String           @unique
  defaultReviewPolicy            ReviewPolicyMode
  createdBy                      String
  llmConfig                      Json?
  imageGenerationConfig          Json?
  imageProviders                 Json?
  videoProviders                 Json?
  defaultImageProvider           String?
  defaultVideoProvider           String?
  projectRolePermissionTemplates Json?
  createdAt                      DateTime         @default(now())
  updatedAt                      DateTime         @updatedAt

  members     TeamMember[]
  inviteLinks TeamInviteLink[]
  projects    Project[]
}

model TeamMember {
  id        String   @id
  createdAt DateTime @default(now())
  role      TeamRole
  teamId    String
  userId    String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model TeamInviteLink {
  id        String    @id
  teamId    String
  token     String    @unique
  role      TeamRole
  maxUses   Int
  uses      Int
  expiresAt DateTime?
  createdBy String
  createdAt DateTime  @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([expiresAt])
}

model Project {
  id               String           @id
  teamId           String
  name             String
  description      String
  genre            String?
  coverUrl         String?
  status           ProjectStatus
  reviewPolicyMode ReviewPolicyMode
  createdBy        String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  team                 Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members              ProjectMember[]
  invites              ProjectInvite[]
  documents            Document[]
  jobs                 Job[]
  assets               Asset[]
  auditConfigs         AuditConfig[]
  auditRecords         AuditRecord[]
  versionDependencies  VersionDependency[]
  impactIssues         ImpactIssue[]
  impactTargets        ImpactTarget[]
  impactSuggestions    ImpactSuggestion[]
  impactIssueEvents    ImpactIssueEvent[]
  batchJobs            BatchJobGroup[]
  timeline             Timeline?
  exports              Export[]
  notifications        Notification[]
  conversationSessions ConversationSession[]
  novelImportSessions  NovelImportSession[]

  @@index([teamId])
  @@index([status])
  @@index([updatedAt])
}

model ProjectInvite {
  id        String              @id
  projectId String
  email     String
  role      ProjectRole
  createdBy String
  status    ProjectInviteStatus
  createdAt DateTime            @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([email])
}

model ProjectMember {
  id                 String      @id
  createdAt          DateTime    @default(now())
  role               ProjectRole
  projectId          String
  userId             String
  permissionOverride Json?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Document {
  id               String       @id
  projectId        String
  type             DocumentType
  title            String
  shotId           String?
  currentVersionId String?
  draftVersionId   String?
  createdBy        String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions Version[]

  @@index([projectId, type])
  @@index([shotId])
  @@index([currentVersionId])
  @@index([draftVersionId])
}

model Version {
  id              String        @id
  documentId      String
  versionNumber   Int
  status          VersionStatus
  title           String
  content         Json
  metadata        Json
  parentVersionId String?
  createdBy       String
  createdAt       DateTime      @default(now())

  document      Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  parentVersion Version?      @relation("VersionTree", fields: [parentVersionId], references: [id])
  childVersions Version[]     @relation("VersionTree")
  comments      Comment[]
  auditRecords  AuditRecord[]

  @@unique([documentId, versionNumber])
  @@index([documentId, status, createdAt])
  @@index([createdAt])
  @@index([parentVersionId])
}

model Comment {
  id         String     @id
  versionId  String
  authorId   String
  body       String
  parentId   String?
  anchorType AnchorType
  anchorId   String?
  resolved   Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  version Version   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentThread")

  @@index([versionId, parentId])
  @@index([authorId])
}

model Job {
  id          String       @id
  type        JobType
  status      JobStatus
  projectId   String
  documentId  String?
  shotId      String?
  input       Json
  result      Json?
  error       String?
  progress    Int?
  retryCount  Int?
  maxRetries  Int?
  priority    JobPriority?
  cancelledAt DateTime?
  batchId     String?
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status, updatedAt])
  @@index([status, priority, createdAt])
  @@index([documentId])
  @@index([shotId])
  @@index([batchId])
}

model Asset {
  id            String   @id
  projectId     String
  documentId    String?
  versionId     String?
  storageDriver String
  storageKey    String
  publicUrl     String?
  mimeType      String
  sizeInBytes   Int
  createdBy     String
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([documentId])
  @@index([versionId])
}

model AuditConfig {
  id               String           @id
  projectId        String
  contentType      AuditContentType
  reviewRequired   Boolean
  autoApproveRoles Json
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, contentType])
}

model AuditRecord {
  id           String       @id
  projectId    String
  versionId    String
  documentType DocumentType
  action       AuditAction
  reviewerId   String
  comment      String?
  createdAt    DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version Version @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([versionId])
}

model Notification {
  id            String           @id
  userId        String
  projectId     String?
  type          NotificationType
  title         String
  body          String
  referenceId   String?
  referenceType String?
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([projectId])
}

model BatchJobGroup {
  id        String         @id
  projectId String
  jobIds    String[]
  status    BatchJobStatus
  createdBy String
  createdAt DateTime       @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model Timeline {
  id         String   @id
  projectId  String   @unique
  duration   Float
  fps        Int
  resolution String
  tracks     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Export {
  id          String       @id
  projectId   String
  taskId      String
  resolution  String
  fps         Int
  bitrate     String?
  format      ExportFormat
  outputUrl   String?
  fileSize    Int?
  duration    Float?
  status      ExportStatus
  createdBy   String
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([taskId])
}

model VersionDependency {
  id                 String                @id
  projectId          String
  sourceDocumentId   String?
  sourceVersionId    String?
  sourceDocumentType DocumentType?
  targetDocumentId   String
  targetVersionId    String
  targetDocumentType DocumentType
  dependencyType     DependencyType
  targetAnchorType   DependencyAnchorType?
  targetAnchorId     String?
  sourceSnapshotHash String?
  targetSnapshotHash String?
  promptSnapshot     Json?
  provider           String?
  model              String?
  configSource       String?
  createdBy          String
  createdAt          DateTime              @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([sourceVersionId])
  @@index([targetVersionId])
  @@index([targetDocumentId])
}

model ImpactIssue {
  id                      String            @id
  projectId               String
  dependencyId            String?
  sourceDocumentId        String?
  previousSourceVersionId String?
  changedSourceVersionId  String
  targetDocumentId        String
  targetVersionId         String
  dependencyType          DependencyType
  status                  ImpactIssueStatus
  severity                ImpactSeverity
  title                   String
  summary                 String
  assignedTo              String?
  latestSuggestionId      String?
  acceptedSuggestionId    String?
  ignoredBy               String?
  ignoredAt               DateTime?
  ignoreReason            String?
  resolvedBy              String?
  resolvedAt              DateTime?
  resolveNote             String?
  createdBy               String
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targets     ImpactTarget[]
  suggestions ImpactSuggestion[]
  events      ImpactIssueEvent[]

  @@index([projectId, status, updatedAt])
  @@index([targetVersionId])
  @@index([changedSourceVersionId])
}

model ImpactTarget {
  id         String           @id
  issueId    String
  projectId  String
  targetType ImpactTargetType
  documentId String?
  versionId  String?
  anchorId   String?
  label      String?
  createdAt  DateTime         @default(now())

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issue   ImpactIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([projectId])
}

model ImpactSuggestion {
  id                String                 @id
  issueId           String
  projectId         String
  status            ImpactSuggestionStatus
  summary           String
  suggestedContent  Json?
  promptSnapshot    Json?
  provider          String?
  model             String?
  createdVersionId  String?
  createdDocumentId String?
  createdJobId      String?
  acceptedBy        String?
  acceptedAt        DateTime?
  revertedBy        String?
  revertedAt        DateTime?
  createdBy         String
  createdAt         DateTime               @default(now())

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issue   ImpactIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([projectId])
  @@index([createdJobId])
}

model ImpactIssueEvent {
  id        String               @id
  issueId   String
  projectId String
  type      ImpactIssueEventType
  actorId   String
  note      String?
  createdAt DateTime             @default(now())

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issue   ImpactIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId, createdAt])
  @@index([projectId])
}

model ConversationSession {
  id              String   @id
  projectId       String
  messages        Json
  brief           Json
  dimensionStatus Json
  targetDocType   String
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, updatedAt])
  @@index([createdBy])
}

model NovelImportSession {
  id             String            @id
  projectId      String
  createdBy      String
  status         NovelImportStatus
  stage          NovelImportStage
  progress       Int
  sourceText     String
  options        Json
  chunks         Json
  adaptationPlan String?
  worldBible     Json?
  synopsis       String?
  scriptPreview  Json?
  writeResult    Json?
  lastJobId      String?
  error          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, updatedAt])
  @@index([createdBy])
  @@index([lastJobId])
}
