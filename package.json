{
  "name": "dramaflow",
  "version": "0.1.0",
  "private": true,
  "description": "Director-facing short drama generation platform built with TypeScript.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/build-workspace.mjs",
    "dev:api": "npm --workspace @dramaflow/api run start:dev",
    "dev:web": "npm --workspace @dramaflow/web run dev",
    "dev:worker": "npm --workspace @dramaflow/worker run dev",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
